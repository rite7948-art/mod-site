# --- Бот ---
DISCORD_TOKEN=твой_токен_бота
CLIENT_ID=айди_приложения_бота
GUILD_ID=айди_твоего_сервера_для_мгновенной_регистрации_команд
SITE_URL=https://your-railway-domain.up.railway.app
USERS_JSON_PATH=/data/users.json

# --- Сайт (PHP) ---
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=

# --- Sheets sync (см. SHEETS_SYNC_SETUP.md) ---
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_TOKEN=

# --- Discord OAuth (вход через Discord) ---
# 1. Открой Developer Portal → твоё приложение → OAuth2
# 2. В Redirects добавь: http://localhost:8090/auth/discord/callback
# 3. Скопируй Client ID и Client Secret сюда:
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8090/auth/discord/callback
