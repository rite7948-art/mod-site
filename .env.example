# --- Бот ---
DISCORD_TOKEN=твой_токен_бота
CLIENT_ID=айди_приложения_бота
GUILD_ID=айди_твоего_сервера_для_мгновенной_регистрации_команд
SITE_URL=https://your-railway-domain.up.railway.app
USERS_JSON_PATH=/data/users.json

# --- Сайт (PHP) ---
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=

# --- Sheets sync (см. SHEETS_SYNC_SETUP.md) ---
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_TOKEN=

# --- Discord OAuth (вход через Discord) ---
# 1. Открой Developer Portal → твоё приложение → OAuth2
# 2. В Redirects добавь: http://localhost:8090/auth/discord/callback (и,
#    для прода: https://твой-домен/auth_discord.php)
# 3. Скопируй Client ID и Client Secret сюда:
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8090/auth/discord/callback

# --- Селфбот для сверки модеров и аватарок High staff ---
# SELFBOT_TOKEN — user-токен Discord-аккаунта (не бот-токен!), получить через DevTools
SELFBOT_TOKEN=
MODER_GUILD_ID=531970658633252864
MODER_ROLE_ID=1148609467257208904

# --- Внутренний Node-сервис (sync_service.js) — только для прода ---
# PHP не умеет логиниться в Discord как селфбот, поэтому селфбот-операции
# вынесены в отдельный Node-сервис (Dockerfile.sync), а PHP стучится к нему
# по приватной сети Railway. Локально (local-server.js) не нужны — там всё
# работает в одном процессе.
SYNC_SERVICE_URL=http://sync-service.railway.internal:8091
INTERNAL_SYNC_TOKEN=
